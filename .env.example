# Local Ollama Gemma model. Confirm the exact tag with `ollama list`.
LITELLM_MODEL=ollama_chat/gemma4:26b-mlx

# Local Ollama settings used by app/llm.py for ollama/ollama_chat models.
OLLAMA_API_BASE=http://127.0.0.1:11434
OLLAMA_TEMPERATURE=0
OLLAMA_TOP_P=0.95
OLLAMA_TOP_K=64
OLLAMA_NUM_CTX=32768
OLLAMA_THINK=false

# Optional generic gateway settings for OpenAI-compatible LiteLLM endpoints.
LITELLM_API_BASE=
LITELLM_API_KEY=
LITELLM_PROVIDER=litellm_proxy
LITELLM_TIMEOUT_SECONDS=300

# Configure the key for whichever provider your model uses.
# OpenAI examples: gpt-4o-mini, gpt-4.1-mini
OPENAI_API_KEY=

# Anthropic examples: anthropic/claude-3-5-sonnet, anthropic/claude-3-7-sonnet
ANTHROPIC_API_KEY=

# Gemini examples: gemini/gemini-1.5-flash, gemini/gemini-2.0-flash
GEMINI_API_KEY=

# Mistral examples: mistral/mistral-large-latest
MISTRAL_API_KEY=

# Groq examples: groq/llama-3.1-70b-versatile
GROQ_API_KEY=
